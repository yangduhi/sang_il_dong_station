# Core app
NODE_ENV=development
APP_NAME=Sangil-dong Station Dashboard
APP_BASE_URL=http://localhost:3000
APP_DATA_MODE=local
APP_SOURCE_MODE=sample

# Database
# Leave blank when running in local/sample mode.
# Prefer an IPv4-reachable pooled runtime URL in DATABASE_URL.
# Use DIRECT_DATABASE_URL only when the direct host is reachable from your environment.
DATABASE_URL=
DIRECT_DATABASE_URL=

# External data sources
SEOUL_OPEN_DATA_API_KEY=
DATA_GO_KR_SERVICE_KEY=

# Admin / scheduled jobs
ADMIN_CRON_SECRET=change-me
