{
  "name": "sangildong-station-dashboard",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib tests scripts *.ts *.mjs --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "etl:health": "py -3.11 -m etl.jobs.healthcheck",
    "etl:sample": "py -3.11 -m etl.jobs.run_sample_pipeline",
    "etl:quality": "py -3.11 -m etl.jobs.run_quality_gate",
    "inspect:live": "py -3.11 .\\scripts\\inspect_sources\\check_live_sources.py",
    "preflight": "powershell -ExecutionPolicy Bypass -File ./scripts/preflight.ps1",
    "verify": "powershell -ExecutionPolicy Bypass -File ./scripts/verify.ps1"
  },
  "dependencies": {
    "next": "^15.0.0",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.0.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
